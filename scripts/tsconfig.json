{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": ".",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "types": ["chrome-types"],
    "resolveJsonModule": true
  },
  "include": ["*.ts", "scripts/contentScript.ts", "scripts/background.ts", "scripts/popup.ts", "scripts/types.ts", "scripts/utils.ts", "scripts/webgpu-transcript-processing.ts"],
  "exclude": ["node_modules"]
}
